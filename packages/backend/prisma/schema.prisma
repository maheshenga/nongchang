generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  status    String   @default("active")
  createdAt DateTime @default(now()) @map("created_at")
  users     User[]
  agents    Agent[]

  @@map("tenants")
}

model Agent {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  name     String
  region   String
  status   String @default("active")
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  users    User[]

  @@index([tenantId])
  @@map("agents")
}

model User {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  role         String
  agentId      String?  @map("agent_id")
  username     String   @unique
  passwordHash String   @map("password_hash")
  phone        String?
  wxOpenid     String?  @unique @map("wx_openid")
  displayName  String   @map("display_name")
  status       String   @default("active")
  groupId      String?  @map("group_id")
  createdAt    DateTime @default(now()) @map("created_at")
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  agent        Agent?   @relation(fields: [agentId], references: [id])
  group        UserGroup? @relation(fields: [groupId], references: [id])

  @@index([tenantId])
  @@index([agentId])
  @@index([groupId])
  @@map("users")
}

model Field {
  id          String                                 @id @default(uuid())
  tenantId    String                                 @map("tenant_id")
  ownerId     String                                 @map("owner_id")
  name        String
  area        Float
  iotDeviceId String?                                @map("iot_device_id")
  // PostGIS 地理列:Prisma 以 Unsupported 类型识别(消除列漂移)。
  // GIST 索引 fields_location_gist 由 field_geography 原生 SQL 迁移创建,
  // 无法在 schema 中用 @@index 表达,故 `migrate dev` 会提示一个无害的
  // DROP INDEX —— 切勿接受;生产/CI 统一用 `prisma migrate deploy`(不会提示)。
  location    Unsupported("geography(Point, 4326)")?
  createdAt   DateTime                               @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([ownerId])
  @@map("fields")
}

model Batch {
  id              String   @id @default(uuid())
  tenantId        String   @map("tenant_id")
  ownerId         String   @map("owner_id")
  fieldId         String   @map("field_id")
  batchNo         String   @map("batch_no")
  cropName        String   @map("crop_name")
  plantDate       DateTime @map("plant_date")
  expectedHarvest DateTime @map("expected_harvest")
  status          String
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([ownerId])
  @@map("batches")
}

model FarmRecord {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  batchId    String   @map("batch_id")
  fieldId    String   @map("field_id")
  operatorId String   @map("operator_id")
  action     String
  detail     Json?
  images     Json?
  location   String?
  recordedAt DateTime @map("recorded_at")
  source     String
  supplyId     String?  @map("supply_id")
  supplyAmount Float?   @map("supply_amount")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([batchId])
  @@map("farm_records")
}

model TraceCode {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  batchId   String   @map("batch_id")
  code      String   @unique
  scanCount Int      @default(0) @map("scan_count")
  status    String   @default("active") @map("status")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@map("trace_codes")
}

model TraceEvent {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  batchId    String   @map("batch_id")
  type       String
  title      String
  actor      String
  location   String
  occurredAt DateTime @map("occurred_at")
  payload    Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([batchId])
  @@map("trace_events")
}

model TraceScan {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  code      String
  batchId   String   @map("batch_id")
  ip        String
  userAgent String?  @map("user_agent")
  scannedAt DateTime @default(now()) @map("scanned_at")

  @@index([tenantId])
  @@index([code, scannedAt])
  @@index([batchId])
  @@map("trace_scans")
}

model Supply {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  ownerId   String   @map("owner_id")
  name      String
  unit      String
  total     Float    @default(0)
  used      Float    @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([ownerId])
  @@map("supplies")
}

model SupplyIssue {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  ownerId   String   @map("owner_id")
  supplyId  String   @map("supply_id")
  batchId   String   @map("batch_id")
  amount    Float
  createdAt DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([ownerId])
  @@index([supplyId])
  @@index([batchId, supplyId])
  @@map("supply_issues")
}

model AiProvider {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  name        String
  baseUrl     String   @map("base_url")
  apiKeyEnc   String   @map("api_key_enc")
  textModel   String   @map("text_model")
  visionModel String?  @map("vision_model")
  enabled     Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("ai_providers")
}

model OssConfig {
  id              String   @id @default(uuid())
  tenantId        String   @unique @map("tenant_id")
  region          String
  bucket          String
  accessKeyId     String   @map("access_key_id")
  accessKeySecEnc String   @map("access_key_sec_enc")
  baseUrl         String?  @map("base_url")
  enabled         Boolean  @default(false)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("oss_configs")
}

model IntegrationConfig {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  provider     String   // "wechat" | "xfyun"
  appId        String?  @map("app_id")
  secretEnc    String?  @map("secret_enc")      // 微信 Secret 密文
  apiKeyEnc    String?  @map("api_key_enc")      // 讯飞 APIKey 密文
  apiSecretEnc String?  @map("api_secret_enc")   // 讯飞 APISecret 密文
  enabled      Boolean  @default(false)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // 每租户每类型一条 → upsert
  @@unique([tenantId, provider])
  // 微信 appId 全局唯一:微信登录时用 appId 反查租户(匿名请求定位锚点)
  @@unique([appId])
  @@index([tenantId])
  @@map("integration_configs")
}

model UserGroup {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  name        String
  isDefault   Boolean  @default(false) @map("is_default")
  // 叠加式权限点字符串数组,叠加在 role 底座之上
  permissions Json     @default("[]")
  createdAt   DateTime @default(now()) @map("created_at")
  users       User[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("user_groups")
}

model QuickTemplate {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  name      String
  action    String
  note      String?
  cost      Float?
  labor     Float?
  sort      Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@map("quick_templates")
}
