{
  "name": "nongchang",
  "private": true,
  "scripts": {
    "build:shared": "pnpm --filter @nongchang/shared build",
    "build:backend": "pnpm --filter @nongchang/backend build",
    "build": "pnpm build:shared && pnpm build:backend",
    "build:miniapp": "pnpm --filter @nongchang/miniapp build:weapp",
    "test": "pnpm --filter @nongchang/backend test"
  },
  "engines": { "node": ">=20" },
  "devDependencies": { "typescript": "~5.8.2" },
  "pnpm": {
    "onlyBuiltDependencies": ["@prisma/client", "prisma", "@prisma/engines", "@swc/core"]
  }
}
